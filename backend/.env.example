# Core API Configurations
APP_NAME="AI Customer Retention Platform API"
APP_ENV="development"
DEBUG=True
API_V1_STR="/api"
# Security & Authentication
# WARNING: Change JWT_SECRET to a secure random string in production!
JWT_SECRET="super-secret-key-change-in-production-1234567890"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Database Persistence
DATABASE_URL="sqlite:///./customer_retention.db"
# Machine Learning Model Paths
MODEL_PATH="ml/artifacts/model.pkl"
PIPELINE_PATH="ml/artifacts/pipeline.pkl"
